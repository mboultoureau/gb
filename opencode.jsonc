{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "mcp": {
    "github": {
      "type": "local",
      "command": ["github-mcp-server", "stdio", "--toolsets", "context,issues,pull_requests,repos,projects"],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  }
}
